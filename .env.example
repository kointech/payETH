# --- PAYE / PayETH -- environment variables ------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# -- Deployer / signer ---------------------------------------------------------
# Deployments use `cast wallet` accounts (--account deployer).
# Create one with:  cast wallet import deployer --interactive

# -- Koinon treasury wallet -----------------------------------------------------
# Receives the full 125,000,000 PAYE supply on the home chain.
# Becomes the owner and LZ delegate for all deployed PAYEToken contracts.
# Strongly recommended: use a Gnosis Safe multisig.
TREASURY_ADDRESS=0x...

# -- LayerZero EndpointV2 addresses ---------------------------------------------
# Set LZ_ENDPOINT_ADDRESS to the value matching the target chain before running
# each deployment script.
#
# Mainnet endpoints (same address on every chain -- LayerZero v2):
#   Ethereum  : 0x1a44076050125825900e736c501f859c50fE728c
#   Linea     : 0x1a44076050125825900e736c501f859c50fE728c
#
# Testnet endpoints:
#   Ethereum Sepolia : 0x6EDCE65403992e310A62460808c4b910D972f10f
#   Linea Sepolia    : 0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_ENDPOINT_ADDRESS=0x1a44076050125825900e736c501f859c50fE728c

# -- Chain RPC URLs & Verification ----------------------------------------------
# HOME   = the chain where the full supply is minted
# REMOTE = the chain where supply is bridged to (zero initial supply)
HOME_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
REMOTE_RPC_URL=https://linea-mainnet.infura.io/v3/YOUR_KEY

# Explorer API keys (etherscan / lineascan / arbiscan / etc.)
HOME_VERIFY_KEY=YOUR_KEY
REMOTE_VERIFY_KEY=YOUR_KEY

# -- WirePeers script variables (fill after both chains are deployed) -----------
# LOCAL_PAYE_ADDRESS  = address of PAYEToken on THIS chain
# REMOTE_EID          = LayerZero EID of the PEER chain
# REMOTE_PAYE_ADDRESS = address of PAYEToken on the PEER chain
#
# LayerZero Endpoint IDs (EIDs):
#   Ethereum Mainnet : 30101    Ethereum Sepolia : 40161
#   Linea Mainnet    : 30183    Linea Sepolia    : 40287
#   Arbitrum Mainnet : 30110    Base Mainnet     : 30184
#   Optimism Mainnet : 30111    Polygon Mainnet  : 30109
#   Avalanche Mainnet: 30106    BSC Mainnet      : 30102
LOCAL_PAYE_ADDRESS=0x...
REMOTE_EID=30183
REMOTE_PAYE_ADDRESS=0x...
